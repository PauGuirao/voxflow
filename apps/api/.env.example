API_PORT=8788

# Public wss:// URL of the agent runtime. Assigning an agent sets a Zernio
# number's forwardTo to `${AGENT_PUBLIC_WSS_URL}/?agentId=<id>`.
AGENT_PUBLIC_WSS_URL=ws://localhost:8787

# Zernio API base (override for staging). The API key itself is NOT stored here —
# the studio sends it per request as the `x-zernio-key` header.
ZERNIO_API_BASE=https://zernio.com/api
