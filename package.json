{
  "name": "voxflow",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source visual builder for AI voice agents, running on the Zernio telephony API (PSTN + WhatsApp calling).",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "dev:agent": "pnpm --filter @voxflow/agent dev",
    "dev:studio": "pnpm --filter @voxflow/studio dev"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}
