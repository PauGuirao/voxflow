# Zernio API — provisions numbers and assigns agents (sets a number's forwardTo).
# Create a key at https://zernio.com/dashboard/api-keys
ZERNIO_API_KEY=
ZERNIO_API_BASE=https://zernio.com/api

# Public wss:// URL where Zernio's media bridge reaches this agent runtime.
# A Zernio number's forwardTo is set to `${AGENT_PUBLIC_WSS_URL}/?agentId=...`.
AGENT_PUBLIC_WSS_URL=wss://your-agent-host.example.com
AGENT_PORT=8787

# Speech providers (bring your own keys). Leave blank to use the built-in
# echo/stub providers so the runtime boots without external services.
DEEPGRAM_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=
